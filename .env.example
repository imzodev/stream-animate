# Streaming Companion Tool — environment variables
#
# Copy this file to `.env` and fill in real values. The `.env` file is
# git-ignored. The app reads LLM_API_KEY at request time and never
# stores the value on disk.
#
# Any OpenAI-compatible API key works: OpenAI, DeepSeek, MiniMax,
# Together, Groq, etc. The key is sent only to the base_url you
# configured in the AI Assistant tab.

LLM_API_KEY=sk-replace-me-with-your-real-key
